# Ethereum Mainnet RPC URL
# Get your API key from Alchemy (https://www.alchemy.com/) or Infura (https://infura.io/)
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Polygon PoS RPC URL with Archive Node Access
# IMPORTANT: You need an archive node to query historical balances
# Alchemy and QuickNode offer archive node access on paid plans
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Heimdall API Configuration
# Root URL for Heimdall API (without trailing slash)
HEIMDALL_RPC_URL=https://heimdall-api.polygon.technology

# PIP-85 Parameters
BLOCK_PRODUCER_COMMISSION=0.26
STAKERS_FEE_RATE=0.5
EQUALITY_FACTOR=0.75

# Output Configuration
OUTPUT_PATH=./output/

# Rate Limiting Configuration
# Adjust these based on your RPC provider's rate limits
MAX_CONCURRENT_REQUESTS=3
REQUEST_DELAY_MS=200
MAX_RETRIES=3

# Logging
LOG_LEVEL=info
NODE_ENV=development
